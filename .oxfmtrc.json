{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "ignorePatterns": [
    "dist/**",
    "node_modules/**",
    "src/components/ui/**",
    "src/routeTree.gen.ts",
    ".github/**",
    "CHANGELOG.md"
  ],
  "printWidth": 120,
  "singleQuote": true,
  "trailingComma": "all",
  "useTabs": false,
  "semi": false,
  "arrowParens": "always",
  "bracketSpacing": true,
  "bracketSameLine": false,
  "sortImports": {
    "groups": [
      "type-import",
      ["value-builtin", "value-external"],
      "type-internal",
      "value-internal",
      ["type-parent", "type-sibling", "type-index"],
      ["value-parent", "value-sibling", "value-index"],
      "unknown"
    ]
  }
}
